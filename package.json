{
  "name": "create-codepen",
  "version": "2.0.3",
  "description": "Create CodePen with API",
  "keywords": [
    "codepen"
  ],
  "homepage": "https://github.com/Mister-Hope/create-codepen",
  "bugs": {
    "url": "https://github.com/Mister-Hope/create-codepen/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Mr.Hope",
    "email": "mister-hope@outlook.com",
    "url": "https://mister-hope.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mister-Hope/create-codepen.git",
    "directory": "packages/theme"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "changelog": " conventional-changelog -p conventionalcommits",
    "clean": "rimraf dist",
    "dev": "vite",
    "lint": "oxlint --fix --deny-warnings --report-unused-disable-directives && oxfmt",
    "lint:check": "oxlint --deny-warnings --report-unused-disable-directives && oxfmt --check",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run --coverage"
  },
  "devDependencies": {
    "@codecov/rollup-plugin": "2.0.1",
    "@mr-hope/tsconfig": "0.0.4",
    "@types/node": "25.9.5",
    "@vitest/coverage-istanbul": "4.1.10",
    "conventional-changelog": "8.0.1",
    "conventional-changelog-conventionalcommits": "10.2.1",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "nano-staged": "1.0.2",
    "oxc-config-hope": "0.3.9",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "picocolors": "1.1.1",
    "rimraf": "6.1.3",
    "tsdown": "0.22.5",
    "typescript": "7.0.2",
    "unrun": "0.3.1",
    "vite": "8.1.3",
    "vitest": "4.1.10"
  },
  "nano-staged": {
    "**/*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts}": "oxlint --fix --deny-warnings --report-unused-disable-directives"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.12.0",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "^22.23.0 || ^24.16.0 || ^26.3.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": ">=22"
  }
}
